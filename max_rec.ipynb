def max_rect(a:list[int])->int:
    if len(a) == 1:
        return a[0]
    return max(a[0], max_rect(a[1:]))

a = [7,3,8,-2]

max_rect(a)

#mas elegante
def max_rect(a:list[int])->int:
    return [a] if  len(a) == 1 else max(a[0], max_rect(a[1:]))

a = [7,3,8,-2]

max_rect(a)
